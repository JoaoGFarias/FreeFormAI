# Based [Vanderbilt University's AI Agents and Agentic AI with Python & Generative AI course ](https://www.coursera.org/learn/ai-agents-python/home/welcome)
# With the support of ChatGPT: https://chatgpt.com/share/69a85b0f-7cc4-8007-80f7-ae215c5f8e78

import json
import os
from typing import List
from pathlib import Path


from litellm import completion

def list_files() -> List[str]:
    """List files in the current directory."""
    return os.listdir(".")

def read_file(file_name: str) -> str:
    """Read a file's contents."""
    try:
        with open(file_name, "r") as file:
            return file.read()
    except FileNotFoundError:
        return f"Error: {file_name} not found."
    except Exception as e:
        return f"Error: {str(e)}"

def terminate(directory: str, files: list[dict]) -> None:
    """Terminate the agent loop with structured output."""
    payload = {"directory": directory, "files": files}
    print("Termination payload:", json.dumps(payload, indent=2, ensure_ascii=False))

    print("\nDirectory:", directory)
    print("Files:")
    for f in files:
        print(f"- {f['name']}: {f['content_summary']}")

def list_dir(path: str = ".") -> List[str]: 
    """List files in a given directory (non-recursive)."""
    p = Path(path)
    if not p.exists():
        return [f"Error: {path} does not exist."]
    if not p.is_dir():
        return [f"Error: {path} is not a directory."]
    return [str(x) for x in sorted(p.iterdir())]

tool_functions = {
    "list_files": list_files,
    "read_file": read_file,
    "list_dir": list_dir,
    "terminate": terminate
}

tools = [
    {
        "type": "function",
        "function": {
            "name": "list_files",
            "description": "Returns a list of files in the directory.",
            "parameters": {"type": "object", "properties": {}, "required": []}
        }
    },
    {
        "type": "function",
        "function": {
            "name": "read_file",
            "description": "Reads the content of a specified file in the directory.",
            "parameters": {
                "type": "object",
                "properties": {"file_name": {"type": "string"}},
                "required": ["file_name"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "terminate",
            "description": "Terminates the conversation with structured output.",
            "parameters": {
                "type": "object",
                "properties": {
                    "directory": {"type": "string"},
                    "files": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {"type": "string"},
                                "content_summary": {"type": "string"}
                            },
                            "required": ["name", "content_summary"]
                        }
                    }
                },
                "required": ["directory", "files"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "list_dir",
            "description": "Returns a list of entries in a directory path.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {"type": "string"},
                },
                "required": ["path"]
            }
        }
    }
]

agent_rules = [{
    "role": "system",
    "content": """
You are an AI agent that can perform tasks by using available tools.

If a user asks about files, documents, or content, first list the files before reading them.

When you call the terminate tool, the message MUST follow this format:

Directory: <directory_path>

Files:
- <file_name>: <short description of contents>
- <file_name>: <short description of contents>

Do not add any extra text outside this format.
"""
}]

# Initialize agent parameters
iterations = 0
max_iterations = 10

user_task = input("What would you like me to do? ")

memory = [{"role": "user", "content": user_task}]

# The Agent Loop
while iterations < max_iterations:
    iterations += 1

    messages = agent_rules + memory

    response = completion(
        model="openai/gpt-4o",
        messages=messages,
        tools=tools,
        max_tokens=1024
    )

    msg = response.choices[0].message

    assistant_entry = {
        "role": "assistant",
        "content": msg.content or ""
    }

    if getattr(msg, "tool_calls", None):
      assistant_entry["tool_calls"] = []
      for tc in msg.tool_calls:
          assistant_entry["tool_calls"].append({
              "id": tc.id,
              "type": tc.type,
              "function": {
                  "name": tc.function.name,
                  "arguments": tc.function.arguments,
              }
          })

    memory.append(assistant_entry)

    tool_calls = getattr(msg, "tool_calls", None)

    if not tool_calls:
        print(f"Response: {msg.content}")
        break

    for tc in tool_calls:
        tool_name = tc.function.name
        raw_args = tc.function.arguments or "{}"

        try:
            tool_args = json.loads(raw_args)
        except json.JSONDecodeError:
            tool_args = {}
            tool_result = {"error": f"Tool args were not valid JSON: {raw_args}"}
        else:
            if tool_name not in tool_functions:
                tool_result = {"error": f"Unknown tool: {tool_name}"}
            else:
                print(f"Executing: {tool_name} with args {tool_args}")
                try:
                    out = tool_functions[tool_name](**tool_args)
                    tool_result = {"result": out}
                except Exception as e:
                    tool_result = {"error": f"Error executing {tool_name}: {type(e).__name__}: {str(e)}"}

        print(f"Result: {tool_result}")

        # Feed tool result back with role="tool" and the matching tool_call_id
        memory.append({
            "role": "tool",
            "tool_call_id": tc.id,  # <-- the key piece
            "name": tool_name,
            "content": json.dumps(tool_result)
        })

        # If terminate was called, stop immediately
        if tool_name == "terminate":
            break

    if tool_name == "terminate":
        break
